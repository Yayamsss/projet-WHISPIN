<?xml version="1.0" encoding="UTF-8"?>

<!-- pom.xml : c'est le fichier de config de Maven. Maven c'est un outil qui
     gère automatiquement les bibliothèques dont on a besoin (ici JavaFX),
     et qui compile le projet avec une seule commande. Sans ce fichier,
     Maven ne sait pas quoi faire. -->

<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <!-- version du format de ce fichier, on touche pas à ça -->
    <modelVersion>4.0.0</modelVersion>

    <!-- identifiant du projet : groupId c'est genre le "namespace",
         artifactId c'est le nom du projet, version c'est la version -->
    <groupId>fr.univ.quantum</groupId>
    <artifactId>quantum</artifactId>
    <version>1.0</version>
    <packaging>jar</packaging> <!-- on veut produire un fichier .jar à la fin -->
    <name>Quantum</name>       <!-- juste le nom affiché, rien de technique -->

    <properties>
        <!-- on compile en Java 25 parce que le code utilise les "flexible constructors"
             qui n'existent que depuis Java 25. Si on met 21 ici ça compile pas. -->
        <maven.compiler.release>25</maven.compiler.release>

        <!-- encodage des fichiers sources, UTF-8 pour éviter les problèmes
             avec les caractères spéciaux genre les accents -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- version de JavaFX qu'on veut télécharger.
             23.0.2 c'est la dernière version stable compatible Java 25 -->
        <javafx.version>23.0.2</javafx.version>

        <!-- par défaut on est sur Linux. Cette valeur change selon l'OS
             grâce aux profils définis plus bas dans le fichier -->
        <javafx.platform>linux</javafx.platform>
    </properties>

    <!-- les dépendances = les bibliothèques externes dont on a besoin.
         Maven va les télécharger automatiquement depuis internet (Maven Central).
         On n'a pas besoin d'installer JavaFX à la main, c'est l'avantage. -->
    <dependencies>

        <!-- javafx-base : les classes de base de JavaFX (observables, bindings...) -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-base</artifactId>
            <version>${javafx.version}</version>
            <!-- le classifier dit à Maven quel binaire télécharger selon l'OS.
                 ${javafx.platform} vaut "linux", "win" ou "mac" -->
            <classifier>${javafx.platform}</classifier>
        </dependency>

        <!-- javafx-controls : les composants graphiques (boutons, labels, etc.) -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
            <classifier>${javafx.platform}</classifier>
        </dependency>

        <!-- javafx-graphics : le moteur de rendu graphique, les formes, les images,
             les animations. C'est le plus important des trois pour notre jeu. -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-graphics</artifactId>
            <version>${javafx.version}</version>
            <classifier>${javafx.platform}</classifier>
        </dependency>

    </dependencies>

    <build>
        <!-- nos fichiers .java sont directement dans src/ et pas dans src/main/java/
             comme Maven s'y attend normalement. On le précise ici sinon Maven
             cherche au mauvais endroit et ne trouve rien. -->
        <sourceDirectory>src</sourceDirectory>

        <plugins>

            <!-- plugin de compilation Java.
                 Sans ça Maven utilise une vieille version de Java par défaut. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <release>25</release>         <!-- Java 25 obligatoire -->
                    <encoding>UTF-8</encoding>
                    <compilerArgs>
                        <!-- active les fonctionnalités "preview" de Java 25,
                             dont les flexible constructors utilisés dans le code -->
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- plugin JavaFX : permet de lancer le jeu avec "mvn javafx:run"
                 sans avoir à se battre avec le module-path de JavaFX à la main -->
            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>0.0.8</version>
                <configuration>
                    <!-- classe principale à lancer, celle qui contient le main() -->
                    <mainClass>Program</mainClass>
                    <options>
                        <!-- pareil qu'à la compilation, on active le preview au lancement -->
                        <option>--enable-preview</option>
                        <!-- autorise JavaFX à accéder à des APIs natives du système,
                             nécessaire pour l'affichage sur certaines configs -->
                        <option>--enable-native-access=javafx.graphics</option>
                    </options>
                </configuration>
            </plugin>

            <!-- plugin qui copie le dossier assets/ dans target/assets/ au moment
                 du build. Sans ça les images du jeu ne sont pas trouvées à l'exécution
                 car Maven compile dans target/ et pas à la racine du projet. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>3.3.1</version>
                <executions>
                    <execution>
                        <id>copy-assets</id>
                        <phase>process-resources</phase> <!-- exécuté avant la compilation -->
                        <goals><goal>copy-resources</goal></goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/assets</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>assets</directory>
                                    <!-- filtering=false : on ne remplace pas les variables
                                         dans les fichiers, on copie tel quel -->
                                    <filtering>false</filtering>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- plugin shade : crée un "fat JAR" avec toutes les dépendances dedans.
                 Utile si on veut distribuer le jeu en un seul fichier .jar.
                 Se lance avec "mvn package", produit target/quantum-full.jar -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.2</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals><goal>shade</goal></goals>
                        <configuration>
                            <outputFile>${project.build.directory}/quantum-full.jar</outputFile>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <!-- indique au JAR quelle classe lancer par défaut -->
                                    <mainClass>Program</mainClass>
                                    <manifestEntries>
                                        <!-- nécessaire quand on mélange des .class de
                                             versions différentes dans un même JAR -->
                                        <Multi-Release>true</Multi-Release>
                                    </manifestEntries>
                                </transformer>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <!-- on exclut les fichiers de signature des JARs
                                             tiers sinon Java refuse de les charger -->
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

        </plugins>
    </build>

    <!-- profils : Maven détecte automatiquement l'OS et change javafx.platform
         en conséquence. Comme ça le bon binaire JavaFX est téléchargé selon
         si on est sur Linux, Windows ou macOS. -->
    <profiles>

        <!-- si on est sur Windows, on télécharge le JavaFX pour Windows -->
        <profile>
            <id>windows</id>
            <activation><os><family>windows</family></os></activation>
            <properties><javafx.platform>win</javafx.platform></properties>
        </profile>

        <!-- si on est sur macOS, on télécharge le JavaFX pour macOS -->
        <profile>
            <id>mac</id>
            <activation><os><family>mac</family></os></activation>
            <properties><javafx.platform>mac</javafx.platform></properties>
        </profile>

        <!-- Linux : c'est la valeur par défaut définie dans <properties> en haut,
             donc pas besoin d'un profil explicite -->

    </profiles>

</project>
